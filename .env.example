# Copy this file to `.env` and adjust as needed.
# KAEL runs on a FREE local model (Ollama) out of the box — no keys required.

# ---- Local model (Ollama) — the free default ----
# Install Ollama from https://ollama.com, then pull a model: `ollama pull llama3.2`
# These have sensible defaults; only set them to override.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# How long Ollama keeps the model in memory between turns (faster replies while
# warm). Default 30m. Use "-1" to keep it loaded forever, or "10m" to free memory
# sooner when idle.
OLLAMA_KEEP_ALIVE=30m
# Try a bigger model for sharper answers if your machine can handle it, e.g.:
# OLLAMA_MODEL=qwen2.5
# OLLAMA_MODEL=llama3.1

# Which backend KAEL starts on: "ollama" (free, local) or "claude". Default ollama.
# You can also flip this live from the button in the UI.
KAEL_PROVIDER=ollama

# ---- Claude (optional, paid) ----
# Only needed if you want to switch KAEL to Claude. Get a key at
# https://console.anthropic.com/ . Without it, the Claude switch is disabled and
# KAEL just stays on the free local model.
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6

# ---- Premium voice (optional, paid) ----
# By default KAEL speaks with your browser's built-in (free) voice. Set an
# OpenAI key to unlock a much smoother neural voice, toggled in ⚙ Settings.
# Get a key at https://platform.openai.com/api-keys . At single-user volume this
# costs roughly a dollar a month. Without it, KAEL just uses the free voice.
OPENAI_API_KEY=
# Model: tts-1-hd (best quality) or tts-1 (cheaper, ~half the cost).
OPENAI_TTS_MODEL=tts-1-hd
# Default voice: alloy, echo, fable, onyx, nova, or shimmer (shimmer = softest).
OPENAI_TTS_VOICE=shimmer

# ---- Web search ----
# KAEL searches the web on its own when a question needs current info — works with NO
# key (it falls back to a free DuckDuckGo search). Set a Brave Search API key for
# sharper results + higher limits (free tier ~2000/mo: https://brave.com/search/api/).
# Optional.
BRAVE_API_KEY=

# ---- Ambient awareness (optional, off by default) ----
# KAEL can glance at a screen you share + a webcam frame and remember what you're
# doing, via a LOCAL vision model. Turn it on in the UI (⚙ Settings → Awareness);
# these just set defaults. Pull the model first: `ollama pull qwen2.5vl:3b`.
AWARENESS_MODEL=qwen2.5vl:3b
# How long to keep the vision model warm between glances (default 10m).
AWARENESS_KEEP_ALIVE=10m
# Awareness sends screen/webcam frames to the vision model, so it REFUSES a non-local
# OLLAMA_URL (frames must never leave your machine). Set this to 1 only if you really
# want to allow a remote vision model and accept that frames leave the box.
# AWARENESS_ALLOW_REMOTE=1

# ---- Server ----
# Port to run on (default 3000).
PORT=3000

# Copy this file to `.env` and fill in your keys.

# Required — your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Brave Search API key for live web search.
# Free tier: https://brave.com/search/api/
# If omitted, KAEL still works; it just answers from knowledge instead of searching.
BRAVE_API_KEY=

# Optional — port to run on (default 3000).
PORT=3000
